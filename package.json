{
  "name": "@sanurb/shiro-cli",
  "version": "0.4.0",
  "description": "Local-first PDF/Markdown knowledge engine — CLI distributed via GitHub Releases",
  "license": "MIT OR Apache-2.0",
  "author": "sanurb",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanurb/shiro.git"
  },
  "homepage": "https://github.com/sanurb/shiro",
  "bugs": {
    "url": "https://github.com/sanurb/shiro/issues"
  },
  "keywords": [
    "shiro",
    "knowledge-base",
    "pdf",
    "markdown",
    "search",
    "cli"
  ],
  "bin": {
    "shiro": "bin/shiro"
  },
  "files": [
    "README.md",
    "install.js",
    "bin/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "os": ["linux", "darwin"],
  "scripts": {
    "postinstall": "node install.js",
    "test": "cargo test",
    "prepare": "command -v lefthook >/dev/null 2>&1 && lefthook install || true",
    "version-sync": "bash scripts/version-sync.sh --write",
    "tag-release": "bash scripts/tag-release.sh"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "lefthook": "^2.1.2"
  }
}
